{
    "info": {
        "name": "Symfony Loans API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get All Loans",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/loans",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "loans"
                    ]
                }
            }
        },
        {
            "name": "Create Loan",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"borrower\": \"John Doe\",\n    \"amount\": 1500.00,\n    \"interest_rate\": 5.5\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/loans",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "loans"
                    ]
                }
            }
        },
        {
            "name": "Get Single Loan",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/loans/1",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "loans",
                        "1"
                    ]
                }
            }
        },
        {
            "name": "Update Loan",
            "request": {
                "method": "PATCH",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"amount\": 2000.00\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/loans/1",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "loans",
                        "1"
                    ]
                }
            }
        },
        {
            "name": "Delete Loan",
            "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/loans/1",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "loans",
                        "1"
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000"
        }
    ]
}
