{
    "info": {
        "name": "Laravel Items API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get All Items",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/items",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "items"
                    ]
                }
            }
        },
        {
            "name": "Create Item",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Test Item\",\n    \"description\": \"This is a test item\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/items",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "items"
                    ]
                }
            }
        },
        {
            "name": "Get Single Item",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/items/1",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "items",
                        "1"
                    ]
                }
            }
        },
        {
            "name": "Update Item",
            "request": {
                "method": "PATCH",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Updated Item\",\n    \"description\": \"Updated description\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/api/items/1",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "items",
                        "1"
                    ]
                }
            }
        },
        {
            "name": "Delete Item",
            "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/api/items/1",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "items",
                        "1"
                    ]
                }
            }
        }
    ],
    "variable": [
